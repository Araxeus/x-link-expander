{
  "manifest_version": 3,
  "name": "X Link Expander",
  "description": "Redirects t.co shortened URLs to expandurl.net for expansion, useful when t.co domains don't resolve on your network.",
  "version": "1.0.0",
  "permissions": ["webNavigation", "tabs", "storage", "offscreen"],
  "host_permissions": ["https://t.co/*", "http://t.co/*", "https://www.expandurl.net/*", "http://www.expandurl.net/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
